# Runtime data
data/
memory/
*.pyc
__pycache__/
.pytest_cache/

# Drift sentinel runtime state (do not commit — scan output + binary history)
drift_sentinel/drift_history.db
drift_sentinel/drift_history.db-*
drift_sentinel/reports/

# Human-override + codification SQLite runtime stores (per-engine, never commit)
drift_sentinel/human_overrides.db
drift_sentinel/human_overrides.db-*
drift_sentinel/codification_proposals.db
drift_sentinel/codification_proposals.db-*
drift_sentinel/llm_audit.db
drift_sentinel/llm_audit.db-*

# OVS-Calibration runtime state (per-deploy DB; HMAC-signed MD twins are
# emitted into calibration-revisions/ at runtime — do not commit local dev
# artifacts. Production deploys mount this directory from durable storage.)
drift_sentinel/ovs_calibration.db
drift_sentinel/ovs_calibration.db-*
calibration-revisions/

# Codification proposer artifacts (per-deploy `.md` twins emitted by
# engine/codification/proposer.py at runtime — runtime state, not source).
codification-proposals/

# Environment
.env
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
